# Supabase project (AI CRM)
# Project ref: bwumqahgwobwghlmzcrl
# Region: South Asia (Mumbai)

SUPABASE_URL=https://bwumqahgwobwghlmzcrl.supabase.co

# Publishable (anon) key — safe for client-side use
SUPABASE_PUBLISHABLE_KEY=

# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (replace [YOUR-PASSWORD] with the DB password from
# Supabase dashboard → Project Settings → Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.bwumqahgwobwghlmzcrl.supabase.co:5432/postgres

# --- Frontend variants (e.g. Next.js / Vite) ---
# Uncomment whichever framework you use. Same values, different prefix.

# Next.js
# NEXT_PUBLIC_SUPABASE_URL=https://bwumqahgwobwghlmzcrl.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Vite
# VITE_SUPABASE_URL=https://bwumqahgwobwghlmzcrl.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Model Gateway (D-009) ---
# All LLM calls route through src/lib/ai/gateway.ts. Anthropic primary,
# OpenAI fallback. Server-only — never expose to client.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- WhatsApp inbound webhook (D-010) ---
# Shared secret used to HMAC-SHA256-sign inbound webhook bodies.
# The provider sends the digest in the `x-wa-signature` header. Server-
# only. Set the same value in your WhatsApp provider's webhook config.
WHATSAPP_WEBHOOK_SECRET=

# --- Cross-product event bus (D-013) ---
# Shared secret used to HMAC-SHA256-sign /api/events/inbox bodies.
# Hand the same value to Call Audit / Legal Auditor / MIH so their
# emitters can sign envelopes. Server-only.
BUILTRIX_EVENT_INBOX_SECRET=
