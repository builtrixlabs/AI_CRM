# Supabase project (AI CRM)
# Project ref: bwumqahgwobwghlmzcrl
# Region: South Asia (Mumbai)

SUPABASE_URL=https://bwumqahgwobwghlmzcrl.supabase.co

# Publishable (anon) key — safe for client-side use
SUPABASE_PUBLISHABLE_KEY=

# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (replace [YOUR-PASSWORD] with the DB password from
# Supabase dashboard → Project Settings → Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.bwumqahgwobwghlmzcrl.supabase.co:5432/postgres

# --- Frontend variants (e.g. Next.js / Vite) ---
# Uncomment whichever framework you use. Same values, different prefix.

# Next.js
# NEXT_PUBLIC_SUPABASE_URL=https://bwumqahgwobwghlmzcrl.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Vite
# VITE_SUPABASE_URL=https://bwumqahgwobwghlmzcrl.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Provider keys + webhook secrets (D-016) ---
# These are now configured by a super_admin in
# /platform/settings/secrets and stored in the `platform_secrets`
# table. The env vars below are FALLBACKS only — getSecret() reads
# the DB row first, then falls back to env. After the super_admin
# saves a value in the UI, the DB row takes priority and the env
# var becomes informational.
#
# Do NOT set these in production unless you intentionally want a
# bootstrap fallback before the super_admin first logs in.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
WHATSAPP_WEBHOOK_SECRET=
BUILTRIX_EVENT_INBOX_SECRET=
